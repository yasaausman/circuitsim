{
  "buildCommand": "(cd apps/web && bun run build) && ./node_modules/.bin/esbuild api/_entry.ts --bundle --platform=node --format=cjs --outfile=api/index.js",
  "installCommand": "bun install",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
